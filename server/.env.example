# Copy this file to .env and fill in your values.
# For Render production, set these in the Render dashboard (Environment tab).

# Port the server listens on (Render sets this automatically)
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/formcraft?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# Frontend origin allowed by CORS (no trailing slash).
# Use a comma-separated list for multiple origins, e.g. staging + production.
CLIENT_URL=http://localhost:5173
