# Copy this file to .env and fill in your values.
# For local dev, the defaults below work out of the box.
# For Vercel production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# URL of the deployed backend API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Public URL of the frontend app — used for share links in the form builder
VITE_APP_URL=http://localhost:5173
